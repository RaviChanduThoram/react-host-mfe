{
  "name": "react-host-mfe",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/react-host-mfe/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/react-host-mfe"],
      "options": {
        "command": "webpack --config webpack.config.js",
        "cwd": "{projectRoot}"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack serve --config webpack.config.js --port 4200",
        "cwd": "{projectRoot}"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rimraf dist/apps/react-host-mfe",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
